# MAZLUM Configuration
# Copy to .env and fill in your values

# ── API Keys (ZORUNLU) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Mode ──────────────────────────────────────────
# cli | web | telegram | all
SERIAI_MODE=all

# ── Models ────────────────────────────────────────
# SERIAI_COGNITION_MODEL=claude-sonnet-4-20250514
# SERIAI_LIGHT_MODEL=claude-haiku-4-5-20251001
# SERIAI_VOICE_MODEL=gemini-2.5-flash-preview-native-audio-dialog

# ── Owner ─────────────────────────────────────────
# SERIAI_OWNER_NAME=Doğan

# ── Telegram Bot ──────────────────────────────────
# SERIAI_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# SERIAI_TELEGRAM_ALLOWED_USERS=123456789,987654321

# ── Telegram User API (hesap izleme) ─────────────
# my.telegram.org'dan alınır
# SERIAI_TG_API_ID=12345678
# SERIAI_TG_API_HASH=abcdef1234567890abcdef1234567890
# SERIAI_TG_PHONE=+905xxxxxxxxx

# ── Database (read-only) ─────────────────────────
# SERIAI_DB_ENGINE=postgresql
# SERIAI_DB_HOST=localhost
# SERIAI_DB_PORT=5432
# SERIAI_DB_NAME=mydb
# SERIAI_DB_USER=readonly_user
# SERIAI_DB_PASSWORD=secret

# ── Features ─────────────────────────────────────
# SERIAI_ENABLE_VOICE=true
# SERIAI_ENABLE_WEB_UI=true
# SERIAI_ENABLE_LEGAL_PACK=false
# SERIAI_ENABLE_PROACTIVE=true

# ── Monitoring / Alerting ────────────────────────
# SERIAI_ALERT_CHAT_IDS=123456789
# SERIAI_ALERT_INTERVAL=300
# SERIAI_ALERT_THRESHOLD=10
# SERIAI_MONITOR_INTERVAL=300
# SERIAI_DEAD_LETTER_THRESHOLD=10
# SERIAI_PENDING_TX_THRESHOLD=100
# SERIAI_VOICE_NOTIFY_COOLDOWN=300

# ── Cost Control ─────────────────────────────────
# SERIAI_MAX_DAILY_COST=10.0

# ── App ──────────────────────────────────────────
# SERIAI_WEB_PORT=8420
# SERIAI_LOG_LEVEL=INFO
# SERIAI_DEBUG=false
# SERIAI_LANGUAGE=tr
